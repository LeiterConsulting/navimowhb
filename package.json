{
  "name": "homebridge-navimow",
  "version": "0.1.4",
  "description": "Homebridge platform plugin for Navimow robotic mowers with HomeKit controls, live telemetry, and a guided OAuth setup flow.",
  "displayName": "Navimow for Homebridge",
  "author": {
    "name": "LeiterConsulting",
    "url": "https://github.com/LeiterConsulting"
  },
  "homepage": "https://github.com/LeiterConsulting/navimowhb#readme",
  "bugs": {
    "url": "https://github.com/LeiterConsulting/navimowhb/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeiterConsulting/navimowhb.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json",
    "README.md",
    "info.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "check": "npm run lint && npm run build",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check",
    "release:major": "npm version major",
    "release:minor": "npm version minor",
    "release:patch": "npm version patch",
    "start": "homebridge -U ./test/hbConfig -P .",
    "start:debug": "homebridge -D -U ./test/hbConfig -P .",
    "watch": "nodemon --config nodemon.json"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "navimow",
    "segway",
    "robotic-mower",
    "homekit",
    "lawn-mower"
  ],
  "engines": {
    "node": ">=18.20.0",
    "homebridge": ">=1.8.0"
  },
  "peerDependencies": {
    "homebridge": "^1.8.0"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.14.1",
    "eslint": "^9.39.4",
    "homebridge": "^1.11.3",
    "nodemon": "^3.1.14",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.2"
  },
  "homebridge": {
    "pluginAlias": "NavimowPlatform",
    "pluginType": "platform",
    "singular": true
  }
}
